{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nulqor",
  "version": "0.1.0",
  "identifier": "com.nulqor.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nulqor",
        "fullscreen": false,
        "width": 1,
        "height": 1,
        "x": -10000,
        "y": -10000,
        "center": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "resizable": true,
        "alwaysOnTop": false,
        "visible": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
